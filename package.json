{
  "name": "screen-recorder",
  "version": "1.0.0",
  "description": "Desktop screen recorder with auto zoom/pan effects on clicks and scrolls",
  "author": "Kushal Prajapati",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "start": "npm run build:renderer && electron .",
    "build:renderer": "vite build",
    "build:processor": "node scripts/build-processor.js",
    "prepackage": "npm run build:renderer && npm run build:processor",
    "package": "electron-forge package",
    "premake": "npm run build:renderer && npm run build:processor",
    "make": "electron-forge make"
  },
  "dependencies": {
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "lucide-react": "^0.574.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}
